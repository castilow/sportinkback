# ============================================================
# Sportink Backend — variables de entorno
# Copia este archivo a ".env" y rellena los valores reales.
# NO subas el .env real al repositorio.
# ============================================================

# --- Base de datos Mongo (legacy / opcional) ---
MONGO_URL=
DB_NAME=sportink

# --- Seguridad ---
# Cadena larga y aleatoria para firmar los JWT (>= 32 caracteres)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Cookies seguras: True en producción (HTTPS), False solo en local
COOKIE_SECURE=True

# --- Supabase / Postgres ---
DATABASE_URL=
DIRECT_URL=
SUPABASE_DB_PASSWORD=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# --- CORS ---
# Orígenes del frontend separados por comas (sin "*").
# Ej: dev de la app + landing
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Admin inicial (solo se crea si no existe) ---
ADMIN_EMAIL=admin@sportink.app
ADMIN_PASSWORD=
